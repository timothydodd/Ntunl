# Build
FROM golang:1.23 AS build
WORKDIR /src
COPY go.mod go.sum* ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 go build -o /out/client ./cmd/client

# Run
FROM gcr.io/distroless/static:nonroot
WORKDIR /app
COPY --from=build /out/client /app/client
COPY configs/client.json /app/client.json
USER nonroot:nonroot
ENTRYPOINT ["/app/client", "-config", "/app/client.json"]
