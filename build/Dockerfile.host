# Build
FROM golang:1.23 AS build
WORKDIR /src
COPY go.mod go.sum* ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 go build -o /out/host ./cmd/host

# Run
FROM gcr.io/distroless/static:latest
WORKDIR /data
COPY --from=build /out/host /app/host
COPY configs/host.json /app/host.json
# SQLite DB and generated cert live in the mounted /data volume.
VOLUME ["/data"]
EXPOSE 8001 9200 8002
ENTRYPOINT ["/app/host", "-config", "/app/host.json"]
